{
  "schema_version": "1.0.0",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/hooks/session-start.mjs",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/hooks/delegation-enforce.mjs",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/hooks/approval-gate.mjs",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/hooks/adr-enforce.mjs",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/hooks/cost-track.mjs",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/hooks/keyword-detect.mjs",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/hooks/audit-log.mjs",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/hooks/stop-gate.mjs",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
