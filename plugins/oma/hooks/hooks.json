{
  "schema_version": "1.0.0",
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node ${PLUGIN_ROOT}/hooks/session-start.mjs",
        "timeout": 5000
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "node ${PLUGIN_ROOT}/hooks/delegation-enforce.mjs",
        "timeout": 5000
      },
      {
        "type": "command",
        "command": "node ${PLUGIN_ROOT}/hooks/approval-gate.mjs",
        "timeout": 5000
      },
      {
        "type": "command",
        "command": "node ${PLUGIN_ROOT}/hooks/adr-enforce.mjs",
        "timeout": 5000
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "node ${PLUGIN_ROOT}/hooks/cost-track.mjs",
        "timeout": 5000
      },
      {
        "type": "command",
        "command": "node ${PLUGIN_ROOT}/hooks/keyword-detect.mjs",
        "timeout": 5000
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node ${PLUGIN_ROOT}/hooks/stop-gate.mjs",
        "timeout": 5000
      }
    ]
  }
}
