{
  "schema_version": "1.0.0",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/session-start.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/graph-provider-bridge.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/delegation-enforce.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/approval-gate.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/adr-enforce.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/post-tool-status.js",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/cost-track.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/keyword-detect.js",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/audit-log.js",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${AUGMENT_PLUGIN_ROOT}/dist/hooks/stop-gate.js",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
