{
  "schema_version": "1.0.0",
  "mcp_servers": {
    "oma-state": {
      "command": "node",
      "args": ["${PLUGIN_ROOT}/mcp/state-server.mjs"],
      "env": {},
      "protocol": "stdio"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp-server"],
      "env": {},
      "protocol": "stdio"
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "@exa-js/mcp-server"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "protocol": "stdio"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "protocol": "stdio"
    }
  }
}
