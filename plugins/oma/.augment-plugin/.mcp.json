{
  "schema_version": "1.0.0",
  "mcp_servers": {
    "oma-state": {
      "command": "sh",
      "args": ["-c", "exec node \"${PLUGIN_ROOT}/mcp/state-server.mjs\""],
      "env": {},
      "protocol": "stdio"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {},
      "protocol": "stdio"
    },
    "exa": {
      "command": "npx",
      "args": ["-y", "exa-mcp-server"],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      },
      "protocol": "stdio"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
