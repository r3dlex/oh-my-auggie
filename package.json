{
  "name": "oh-my-auggie",
  "version": "0.3.4",
  "description": "OMA plugin with TypeScript hooks -- Windows-compatible",
  "type": "module",
  "main": "plugins/oma/dist/index.js",
  "bin": {
    "oma": "bin/oma",
    "super-oma": "bin/super-oma"
  },
  "exports": {
    ".": {
      "import": "./plugins/oma/dist/index.js"
    }
  },
  "scripts": {
    "test": "npm --prefix plugins/oma run test",
    "test:coverage": "npm --prefix plugins/oma run coverage",
    "build": "npm --prefix plugins/oma run build",
    "typecheck": "npm --prefix plugins/oma run typecheck"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
